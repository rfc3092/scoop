{
  "version": "v1.14.5",
  "pre_uninstall": [
    "Write-Host 'Stopping naisdevice processes...' -ForegroundColor Yellow",
    "Stop-Process -Name 'naisdevice-systray' -Force -ErrorAction SilentlyContinue",
    "Stop-Process -Name 'naisdevice-agent' -Force -ErrorAction SilentlyContinue",
    "Write-Host 'Prompting for Admin privileges to stop the naisdevice-helper service...' -ForegroundColor Yellow",
    "$helperStopScript = @(",
    "  '$svc = Get-Service -Name ''naisdevice-helper'' -ErrorAction SilentlyContinue'",
    "  'if ($svc -and $svc.Status -ne ''Stopped'') {'",
    "  '  Stop-Service -Name ''naisdevice-helper'' -Force -ErrorAction SilentlyContinue'",
    "  '  try { $svc.WaitForStatus(''Stopped'', [TimeSpan]::FromSeconds(15)) } catch {}'",
    "  '}'",
    "  'Stop-Process -Name ''naisdevice-helper'' -Force -ErrorAction SilentlyContinue'",
    "  'Stop-Process -Name ''naisdevice-agent'' -Force -ErrorAction SilentlyContinue'",
    "  'Stop-Process -Name ''naisdevice-systray'' -Force -ErrorAction SilentlyContinue'",
    ")",
    "$helperStopScriptPath = Join-Path $env:TEMP ('naisdevice-stop-' + [System.Guid]::NewGuid().ToString() + '.ps1')",
    "try {",
    "  Set-Content -Path $helperStopScriptPath -Value $helperStopScript -Encoding Ascii",
    "  $helperStopProcess = Start-Process -FilePath powershell.exe -ArgumentList @('-NoProfile', '-WindowStyle', 'Hidden', '-ExecutionPolicy', 'Bypass', '-File', $helperStopScriptPath) -Verb RunAs -Wait -PassThru -ErrorAction Stop",
    "  if ($helperStopProcess.ExitCode -ne 0) {",
    "    Write-Error \"Failed to stop naisdevice-helper service. Elevated script exited with code $($helperStopProcess.ExitCode).\"",
    "    exit 1",
    "  }",
    "} catch {",
    "  Write-Error \"Failed to stop naisdevice-helper service: $($_.Exception.Message)\"",
    "  exit 1",
    "} finally {",
    "  Remove-Item -Path $helperStopScriptPath -Force -ErrorAction SilentlyContinue",
    "}"
  ],
  "architecture": {
    "64bit": {
      "url": "https://github.com/nais/device/releases/download/v1.14.3/naisdevice_windows_amd64.exe",
      "hash": "82B971E5754C4C4154D8F7A1D1D824C21A9583D66A2B3CE5065FD85310F03AF5",
      "installer": {
        "script": [
          "Write-Output \"Executing installer at $dir\\$fname\"",
          "if (!(Invoke-ExternalCommand \"$dir\\$fname\" /S -RunAs)) {",
          "  exit 1",
          "}"
        ]
      },
      "post_uninstall": [
        "if ($cmd -eq \"uninstall\") {",
        "  $uninstaller = \"$env:ProgramW6432\\NAV\\naisdevice\\uninstaller.exe\"",
        "  if (Test-Path $uninstaller) {",
        "    if (!(Invoke-ExternalCommand $uninstaller /S -RunAs)) {",
        "      exit 1",
        "    }",
        "  } else {",
        "    Write-Host 'naisdevice uninstaller.exe not found; skipping vendor uninstall.' -ForegroundColor Yellow",
        "  }",
        "}"
      ]
    },
    "arm64": {
      "url": "https://github.com/nais/device/releases/download/v1.14.3/naisdevice_windows_arm64.exe",
      "hash": "665D1D500923D9699487695A77CD7F7FF797D827DE459D848DD7546C56CC269C",
      "installer": {
        "script": [
          "Write-Output \"Executing installer at $dir\\$fname\"",
          "if (!(Invoke-ExternalCommand \"$dir\\$fname\" /S -RunAs)) {",
          "  exit 1",
          "}"
        ]
      },
      "post_uninstall": [
        "if ($cmd -eq \"uninstall\") {",
        "  $uninstaller = \"$env:ProgramW6432\\NAV\\naisdevice\\uninstaller.exe\"",
        "  if (Test-Path $uninstaller) {",
        "    if (!(Invoke-ExternalCommand $uninstaller /S -RunAs)) {",
        "      exit 1",
        "    }",
        "  } else {",
        "    Write-Host 'naisdevice uninstaller.exe not found; skipping vendor uninstall.' -ForegroundColor Yellow",
        "  }",
        "}"
      ]
    }
  },
  "homepage": "https://docs.nais.io/operate/naisdevice/how-to/install/",
  "checkver": "github",
  "license": "MIT",
  "description": "naisdevice is a mechanism enabling developers to connect to internal resources in a secure and friendly manner."
}